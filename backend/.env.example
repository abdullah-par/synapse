GROQ_API_KEY=gsk_your_groq_api_key_here
NOTION_API_KEY=                          # optional — only if using Notion sync
FRONTEND_URL=http://localhost:3000       # set to your Vercel URL in production
ENVIRONMENT=development                  # "production" on deploy
PROXY_URL=                               # optional SOCKS5/HTTPS proxy for YouTube
DATABASE_URL=                          # Add a Postgres URL (e.g. from Railway/Supabase) to persist feedback
PORT=8000                                # Render/Railway set this automatically
# Set FEEDBACK_DIR=/mount/data if using persistent volumes instead of a DB
